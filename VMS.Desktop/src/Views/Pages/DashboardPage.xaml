<UserControl x:Class="VMS.Views.Pages.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Background="{DynamicResource BackgroundColor}">
        <StackPanel Margin="28,24,28,28">

            <!-- Page header -->
            <TextBlock Text="{Binding WelcomeMessage}"
                       FontSize="22" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <TextBlock Text="Here's what's happening across your camera network."
                       FontSize="13" Foreground="{DynamicResource TextSecondaryColor}"
                       Margin="0,0,0,28"/>

            <!-- Stat cards row -->
            <UniformGrid Columns="4" Margin="0,0,0,28">

                <Border Background="{DynamicResource CardBackgroundColor}"
                        CornerRadius="6" Margin="0,0,12,0" Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="📷" FontSize="20" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding TotalCameras}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource SecondaryColor}"/>
                        <TextBlock Text="Total Cameras" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryColor}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource CardBackgroundColor}"
                        CornerRadius="6" Margin="0,0,12,0" Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="🟢" FontSize="20" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding OnlineCameras}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource SuccessColor}"/>
                        <TextBlock Text="Online" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryColor}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource CardBackgroundColor}"
                        CornerRadius="6" Margin="0,0,12,0" Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="⏺" FontSize="20" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding Recordings}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource WarningColor}"/>
                        <TextBlock Text="Recording" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryColor}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource CardBackgroundColor}"
                        CornerRadius="6" Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="🚨" FontSize="20" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding ActiveAlarms}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource ErrorColor}"/>
                        <TextBlock Text="Active Alarms" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryColor}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- Recent activity panel -->
            <Border Background="{DynamicResource CardBackgroundColor}"
                    CornerRadius="6" Padding="20,16">
                <StackPanel>
                    <TextBlock Text="Recent Activity" FontSize="14" FontWeight="SemiBold"
                               Margin="0,0,0,16"/>
                    <TextBlock Text="No recent events."
                               Foreground="{DynamicResource TextSecondaryColor}" FontSize="13"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
