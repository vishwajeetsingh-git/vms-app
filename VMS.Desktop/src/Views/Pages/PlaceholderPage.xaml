<UserControl x:Class="VMS.Views.Pages.PlaceholderPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{DynamicResource BackgroundColor}">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="🚧" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,16"/>
            <TextBlock Text="{Binding PageName}" FontSize="20" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="{Binding Message}" FontSize="13"
                       Foreground="{DynamicResource TextSecondaryColor}"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
