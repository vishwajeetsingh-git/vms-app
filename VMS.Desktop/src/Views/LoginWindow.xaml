<inf:ChromeWindow x:Class="VMS.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:inf="clr-namespace:VMS.Infrastructure"
        xmlns:views="clr-namespace:VMS.Views"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="{DynamicResource SurfaceColor}"
        Width="380" Height="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0,0,0,1" ResizeBorderThickness="0" CaptionHeight="36" CornerRadius="0"/>
    </WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom title bar (no min/max) -->
        <views:WindowTitleBar Grid.Row="0" Title="Login"
                              ShowMaximize="False" ShowMinimize="False"/>

        <!-- Login form -->
        <StackPanel Grid.Row="1" Margin="40,20,40,32" VerticalAlignment="Center">

            <!-- App branding -->
            <TextBlock Text="VMS" FontSize="30" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource PrimaryColor}"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Video Management System" FontSize="12"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryColor}"
                       Margin="0,0,0,36"/>

            <!-- Username -->
            <TextBlock Text="USERNAME" FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryColor}" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                     Height="36" Margin="0,0,0,14"/>

            <!-- Password -->
            <TextBlock Text="PASSWORD" FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryColor}" Margin="0,0,0,5"/>
            <PasswordBox x:Name="PwdBox" Height="36" Margin="0,0,0,16"
                         PasswordChanged="PwdBox_PasswordChanged"/>

            <!-- Error message -->
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource ErrorColor}" FontSize="12"
                       HorizontalAlignment="Center" TextWrapping="Wrap"
                       Margin="0,0,0,12">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasError}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Login button -->
            <Button Content="Login" Height="38" FontSize="14" FontWeight="SemiBold"
                    Command="{Binding LoginCommand}" IsDefault="True"/>
        </StackPanel>
    </Grid>
</inf:ChromeWindow>
